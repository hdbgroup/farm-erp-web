# Development Mode
# Set to true to use mock data (perfect for development without Firebase)
# Set to false to use real Firebase services
VITE_USE_MOCK_DATA=true

# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials
# Get these values from Firebase Console > Project Settings > General
# (Only needed when VITE_USE_MOCK_DATA=false)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Optional: Use Firebase Emulators for local development
# (Only used when VITE_USE_MOCK_DATA=false)
VITE_USE_FIREBASE_EMULATORS=false
