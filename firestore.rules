rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    // ============================================
    // Users Collection (also serves as team members/employees)
    // ============================================

    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can create their own profile on first login
      // Admins and managers can create other user profiles
      allow create: if isAuthenticated() && (isOwner(userId) || hasAnyRole(['admin', 'manager']));

      // Users can update their own profile, admins/managers can update any profile
      allow update: if isAdmin() || hasAnyRole(['admin', 'manager']) || isOwner(userId);

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ============================================
    // Inventory Collection
    // ============================================

    match /inventory/{itemId} {
      // All authenticated users can read inventory
      allow read: if isAuthenticated();

      // Farm workers, managers, and admins can create/update inventory
      allow create, update: if hasAnyRole(['admin', 'manager', 'farm_worker']);

      // Only admins can delete inventory items
      allow delete: if isAdmin();
    }

    // ============================================
    // Zones Collection
    // ============================================

    match /zones/{zoneId} {
      // All authenticated users can read zones
      allow read: if isAuthenticated();

      // Farm workers, managers, and admins can manage zones
      allow create, update: if hasAnyRole(['admin', 'manager', 'farm_worker']);

      // Only admins can delete zones
      allow delete: if isAdmin();
    }

    // ============================================
    // Orders Collection
    // ============================================

    match /orders/{orderId} {
      // All authenticated users can read orders
      allow read: if isAuthenticated();

      // Anyone authenticated can create orders (for walk-in customers)
      allow create: if isAuthenticated();

      // Managers, logistics, and admins can update orders
      allow update: if hasAnyRole(['admin', 'manager', 'logistics']);

      // Only admins can delete orders
      allow delete: if isAdmin();
    }

    // ============================================
    // Customers Collection
    // ============================================

    match /customers/{customerId} {
      // All authenticated users can read customer info
      allow read: if isAuthenticated();

      // Anyone can create a customer record
      allow create: if isAuthenticated();

      // Managers, logistics, and admins can update customers
      allow update: if hasAnyRole(['admin', 'manager', 'logistics']);

      // Only admins can delete customers
      allow delete: if isAdmin();
    }

    // ============================================
    // Activities Collection (Activity Logs)
    // ============================================

    match /activities/{activityId} {
      // All authenticated users can read activity logs
      allow read: if isAuthenticated();

      // Anyone authenticated can create activity logs
      allow create: if isAuthenticated();

      // No one can update or delete activity logs (audit trail)
      allow update, delete: if false;
    }

    // ============================================
    // Notifications Collection
    // ============================================

    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // System and admins can create notifications
      allow create: if isAuthenticated();

      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Users can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // Stage Transitions Collection
    // ============================================

    match /stage_transitions/{transitionId} {
      // All authenticated users can read stage transitions
      allow read: if isAuthenticated();

      // Farm workers, managers, and admins can create transitions
      allow create: if hasAnyRole(['admin', 'manager', 'farm_worker']);

      // No one can update transitions (audit trail)
      allow update: if false;

      // Only admins can delete transitions
      allow delete: if isAdmin();
    }

    // ============================================
    // Product Info Collection (Marketplace)
    // ============================================

    match /product_info/{productId} {
      // All authenticated users can read product info
      allow read: if isAuthenticated();

      // Managers and admins can manage product info
      allow create, update: if hasAnyRole(['admin', 'manager']);

      // Only admins can delete product info
      allow delete: if isAdmin();
    }

    // ============================================
    // Default Deny All
    // ============================================

    // Deny access to any other collections not explicitly defined
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
